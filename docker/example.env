# Broker infrastructure
BROKER_TYPE=kafka

# Hierarchical topics: v1.<SYSTEM_NAME>.<INSTANCE_ID>.<component>
TOPIC_VERSION=v1
SYSTEM_NAME=deliverydron
INSTANCE_ID=Delivery001

KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
MQTT_PORT=1883

ADMIN_USER=admin
ADMIN_PASSWORD=admin_secret_123

COMPONENT_USER_A=
COMPONENT_PASSWORD_A=
COMPONENT_USER_B=
COMPONENT_PASSWORD_B=

DOCKER_NETWORK=drones_net
