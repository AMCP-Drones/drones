# Broker and component config (no secrets in repo — set in docker-compose or CI)
BROKER_TYPE=kafka
COMPONENT_ID=delivery_drone
HEALTH_PORT=8080

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_GROUP_ID=delivery_drone_group
# BROKER_USER=
# BROKER_PASSWORD=
# Fallback if KAFKA_BOOTSTRAP_SERVERS not set:
# KAFKA_HOST=localhost
# KAFKA_PORT=9092

# MQTT (when BROKER_TYPE=mqtt)
# MQTT_BROKER=localhost
# MQTT_PORT=1883
# MQTT_QOS=1
# BROKER_USER=
# BROKER_PASSWORD=
