# Broker infrastructure
BROKER_TYPE=mqtt
DELIVERYDRON_ROOT=systems/deliverydron

TOPIC_SCHEME=legacy
TOPIC_PREFIX=
TOPIC_VERSION=v1
SYSTEM_NAME=deliverydron
INSTANCE_ID=Delivery001

KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
MQTT_PORT=1883

# Per-component MQTT/Kafka credentials (instance Delivery001)
SECURITY_MONITOR_BROKER_PASSWORD=sm_sec_Delivery001
JOURNAL_BROKER_PASSWORD=journal_sec_Delivery001
NAVIGATION_BROKER_PASSWORD=nav_sec_Delivery001
MISSION_HANDLER_BROKER_PASSWORD=mh_sec_Delivery001
AUTOPILOT_BROKER_PASSWORD=ap_sec_Delivery001
LIMITER_BROKER_PASSWORD=lim_sec_Delivery001
EMERGENCY_BROKER_PASSWORD=em_sec_Delivery001
MOTORS_BROKER_PASSWORD=mot_sec_Delivery001
CARGO_BROKER_PASSWORD=cargo_sec_Delivery001
TELEMETRY_BROKER_PASSWORD=tel_sec_Delivery001

# Optional external ingress (Mosquitto ACL)
MQTT_EXTERNAL_USERS=nus_ext:mission_handler,orvd_ext:limiter,droneport_ext:emergency
NUS_EXT_PASSWORD=nus_sec
ORVD_EXT_PASSWORD=orvd_sec
DRONEPORT_EXT_PASSWORD=dp_sec

DOCKER_NETWORK=drones_net

# Set by release CI (.github/workflows/firmware-cert.yml) after regulator firmware certification.
# ORVD_CERTIFICATE_ID=
